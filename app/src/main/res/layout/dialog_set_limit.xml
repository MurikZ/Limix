<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Иконка приложения -->
    <ImageView
        android:id="@+id/ivDialogAppIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Название приложения -->
    <TextView
        android:id="@+id/tvDialogAppName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/ivDialogAppIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Текущее время использования -->
    <TextView
        android:id="@+id/tvDialogCurrentUsage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#666666"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvDialogAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Разделитель -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#222222"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvDialogCurrentUsage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Заголовок лимита -->
    <TextView
        android:id="@+id/tvSetLimit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="УСТАНОВИТЬ ЛИМИТ"
        android:textColor="#FF6600"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Отображение выбранного значения -->
    <TextView
        android:id="@+id/tvLimitValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="30 мин"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvSetLimit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SeekBar для выбора лимита -->
    <!-- от 5 минут до 180 минут с шагом 5 -->
    <SeekBar
        android:id="@+id/seekBarLimit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:max="35"
        android:progress="5"
        android:progressTint="#FF6600"
        android:thumbTint="#FF6600"
        app:layout_constraintTop_toBottomOf="@id/tvLimitValue"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Подсказки мин/макс -->
    <LinearLayout
        android:id="@+id/seekLabels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/seekBarLimit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="5 мин"
            android:textColor="#444444"
            android:textSize="11sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3 часа"
            android:textColor="#444444"
            android:textSize="11sp"
            android:gravity="end"/>

    </LinearLayout>

    <!-- Быстрые пресеты -->
    <LinearLayout
        android:id="@+id/presetsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/seekLabels"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 15 мин -->
        <TextView
            android:id="@+id/preset15"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="15м"
            android:textColor="#FF6600"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/preset_background"/>

        <!-- 30 мин -->
        <TextView
            android:id="@+id/preset30"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="30м"
            android:textColor="#FF6600"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/preset_background"/>

        <!-- 1 час -->
        <TextView
            android:id="@+id/preset60"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="1ч"
            android:textColor="#FF6600"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/preset_background"/>

        <!-- 2 часа -->
        <TextView
            android:id="@+id/preset120"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="2ч"
            android:textColor="#FF6600"
            android:textSize="13sp"
            android:gravity="center"
            android:background="@drawable/preset_background"/>

    </LinearLayout>

    <!-- Кнопки -->
    <Button
        android:id="@+id/btnSaveLimit"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginTop="20dp"
        android:background="@drawable/btn_primary"
        android:text="СОХРАНИТЬ"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/presetsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Убрать лимит -->
    <Button
        android:id="@+id/btnRemoveLimit"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:text="Убрать лимит"
        android:textColor="#666666"
        android:textSize="13sp"
        app:layout_constraintTop_toBottomOf="@id/btnSaveLimit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>