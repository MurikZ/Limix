<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:padding="24dp">

    <!-- Заголовок экрана -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нам нужен доступ"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="64dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Без этих разрешений приложение не сможет работать"
        android:textColor="#666666"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Карточка разрешения 1 — статистика -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardUsage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Иконка статуса разрешения — меняется на ✓ когда выдано -->
            <TextView
                android:id="@+id/iconUsage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textColor="#FF6600"
                android:textSize="20sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Статистика использования"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Следим сколько времени ты проводишь в приложениях"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Кнопка выдачи разрешения -->
            <Button
                android:id="@+id/btnUsage"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/btn_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Дать"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <!-- Карточка разрешения 3 — специальные возможности -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAccessibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardUsage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/iconAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textColor="#FF6600"
                android:textSize="20sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Специальные возможности"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Блокируем приложения когда лимит исчерпан"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnAccessibility"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/btn_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Дать"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Карточка разрешения 2 — уведомления -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardAccessibility"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/iconNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○"
                android:textColor="#FF6600"
                android:textSize="20sp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Уведомления"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Предупреждаем когда ты приближаешься к лимиту"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnNotification"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/btn_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Дать"
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <!-- Кнопка продолжить — активна только когда главное разрешение выдано -->
    <Button
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/btn_primary"
        android:text="ПРОДОЛЖИТЬ"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:letterSpacing="0.08"
        android:enabled="false"
        android:alpha="0.4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>