<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="80dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="РЕЙТИНГ"
            android:textColor="@color/orange_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Зарабатывай лимми — попади в топ"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingBottom="20dp"/>

        <!-- My stats card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/pixel_card"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="МОЯ СТАТИСТИКА"
                android:textColor="@color/orange_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Место в рейтинге"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvMyRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="#1"
                    android:textColor="@color/pixel_yellow"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡ Лимми"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvMyLimmies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/orange_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🔥 Стрик"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvMyStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 дней"
                    android:textColor="@color/pixel_green"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Жизни сегодня"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:id="@+id/tvMyLives"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❤ ❤ ❤"
                    android:textSize="18sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Global leaderboard placeholder -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ГЛОБАЛЬНЫЙ РЕЙТИНГ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/pixel_card"
            android:padding="20dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Скоро"
                android:textColor="@color/text_dim"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:gravity="center"
                android:paddingBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Глобальный рейтинг появится\nпосле подключения сервера"
                android:textColor="@color/text_dim"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- How limmies work -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="КАК РАБОТАЮТ ЛИММИ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/pixel_card"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚡ +3 лимми каждые 15 минут без нарушений"
                android:textColor="@color/pixel_green"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❤ Потеря жизни = −25% лимми до конца дня"
                android:textColor="@color/pixel_red"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌙 Жизни восстанавливаются в полночь"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:fontFamily="monospace"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
