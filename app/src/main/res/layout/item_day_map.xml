<?xml version="1.0" encoding="utf-8"?>
<!-- Один элемент карты дня — иконка + задача + статус -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp">

    <!-- Иконка приложения -->
    <!-- фон меняется в зависимости от статуса выполнения -->
    <ImageView
        android:id="@+id/ivMapAppIcon"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:padding="4dp"
        android:background="@drawable/map_item_background"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Галочка если задача выполнена — поверх иконки -->
    <TextView
        android:id="@+id/tvCompleted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓"
        android:textColor="#FF6600"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivMapAppIcon"
        app:layout_constraintEnd_toEndOf="@id/ivMapAppIcon"/>

    <!-- Название приложения под иконкой -->
    <TextView
        android:id="@+id/tvMapAppName"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/ivMapAppIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Описание задачи под названием -->
    <TextView
        android:id="@+id/tvMapTask"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:textColor="#666666"
        android:textSize="10sp"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvMapAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>