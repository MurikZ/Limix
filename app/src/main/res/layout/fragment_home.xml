<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="80dp">

        <!-- ШАПКА: жизни + лимми -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Жизни слева -->
            <TextView
                android:id="@+id/tvLives"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="❤️❤️❤️"
                android:textSize="22sp"/>

            <!-- Название по центру -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="LIMIX"
                android:textColor="@color/orange_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:gravity="center"
                android:letterSpacing="0.1"/>

            <!-- Лимми справа -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="end|center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvLimmies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FF6600"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- БОЛЬШОЙ КРУГОВОЙ ПРОГРЕСС -->
        <!-- FrameLayout позволяет накладывать элементы друг на друга -->
        <FrameLayout
            android:id="@+id/frameCircle"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/headerLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Круговой прогресс-бар -->
            <ProgressBar
                android:id="@+id/circularProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:progressDrawable="@drawable/circular_progress"
                android:max="100"
                android:progress="0"
                android:rotation="-90"/>

            <!-- Время по центру круга -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0м"
                    android:textColor="#FF6600"
                    android:textSize="36sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="used today"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>
        </FrameLayout>

        <!-- СТРИК -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardStreak"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/black_card"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/frameCircle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 day focus streak"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="6dp"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#333333"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#FF6600"
                    android:textSize="8sp"/>

                <TextView
                    android:id="@+id/tvBestStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best: 0"
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- МЕТРИКИ: % лимита, разблокировки, место в рейтинге -->
        <LinearLayout
            android:id="@+id/metricsLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cardStreak"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- % лимита -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvLimitPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="of DL limit"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Разделитель -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#222222"
                android:layout_gravity="center_vertical"/>

            <!-- Лимми всего -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalLimmies"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="limmies"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <!-- Разделитель -->
            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#222222"
                android:layout_gravity="center_vertical"/>

            <!-- Место в рейтинге -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvRank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="global rank"
                    android:textColor="#666666"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>
        </LinearLayout>

        <!-- AI INSIGHT карточка -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAiInsight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/black_card"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/metricsLayout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center_vertical">

                <!-- Иконка ИИ -->
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="⚡"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:background="@drawable/btn_primary"
                    android:textColor="#FFFFFF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI INSIGHT"
                        android:textColor="@color/orange_primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.1"/>

                    <TextView
                        android:id="@+id/tvAiInsight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Анализируем твоё поведение..."
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"
                        android:lineSpacingExtra="2dp"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ЗАГОЛОВОК СПИСКА -->
        <LinearLayout
            android:id="@+id/listHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/cardAiInsight"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MOST USED TODAY"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvViewAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View all →"
                android:textColor="#FF6600"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- СПИСОК ПРИЛОЖЕНИЙ -->
        <!-- wrap_content + nestedScrollView — скролл работает вместе со страницей -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerApps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/listHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>