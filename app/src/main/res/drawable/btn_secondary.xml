<?xml version="1.0" encoding="utf-8"?>
<!-- Pixel-style secondary button: outlined with pixel shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="4dp" android:left="4dp">
        <shape>
            <solid android:color="#1A1A2A"/>
        </shape>
    </item>
    <item android:bottom="4dp" android:right="4dp">
        <shape>
            <solid android:color="#161624"/>
            <stroke android:width="2dp" android:color="@color/orange_primary"/>
        </shape>
    </item>
</layer-list>
