    <item android:top="4dp" android:left="4dp">
        <shape>
            <solid android:color="@color/orange_dark"/>
        </shape>
    </item>
    <item android:bottom="4dp" android:right="4dp">
        <shape>
            <solid android:color="@color/orange_primary"/>
        </shape>
    </item>
</layer-list>
