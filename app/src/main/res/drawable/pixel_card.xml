<?xml version="1.0" encoding="utf-8"?>
<!-- Pixel-style card: dark with border offset shadow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:top="3dp" android:left="3dp">
        <shape>
            <solid android:color="@color/black_border"/>
        </shape>
    </item>
    <item android:bottom="3dp" android:right="3dp">
        <shape>
            <solid android:color="@color/black_card"/>
            <stroke android:width="1dp" android:color="@color/black_border"/>
        </shape>
    </item>
</layer-list>
