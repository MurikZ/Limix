<?xml version="1.0" encoding="utf-8"?>
<!-- selector — это условный оператор для цветов -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Когда вкладка выбрана (state_checked=true) — оранжевый -->
    <item android:color="@color/orange_primary" android:state_checked="true"/>
    <!-- Во всех остальных случаях — серый -->
    <item android:color="@color/text_secondary"/>
</selector>